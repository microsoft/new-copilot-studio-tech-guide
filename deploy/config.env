# BlastBox Omega — deploy configuration
# Sourced by deploy.sh and every step. Only stable, env-independent identifiers
# live here; per-env ids (bot guids, connector apiNames) are resolved at runtime.

# --- Identity / tenant -------------------------------------------------------
TENANT_ID="8a235459-3d2c-415d-8c1e-e2fe133509ad"           # PPlatform
EXPECTED_UPN="EladG@PPlatform.onmicrosoft.com"
DOTNET_ROOT_DIR="/Users/administrator/.dotnet"

# --- Environment minting -----------------------------------------------------
ENV_NAME_PREFIX="copilot-adilei"        # fresh envs are <prefix>-<timestamp>
ENV_TYPE="Developer"                    # Developer SKU == inherently Early Release (Frequent)
ENV_REGION="europe"                     # US custom-code function-app pool is capacity-exhausted; EU works
ENV_CURRENCY="EUR"
ENV_LANGUAGE="English"

# --- Solution ----------------------------------------------------------------
# FULL package: 4 custom-code MCP connectors + 4 bots + 14 botcomponents. Connectors
# are kept IN the solution so the agents' tools resolve to the same connector
# identity post-import. Import registers the connectors but does NOT compile their
# inline code, so steps/30_connectors.sh runs `pac connector update` to deploy it,
# and steps/40_connections.sh creates the no-auth connections. No UI step needed.
SOLUTION_NAME="BlastBoxDeploy"
SOLUTION_ZIP="sample/solution/BlastBoxDemo_1_0_0_4.zip"

# --- Connectors --------------------------------------------------------------
# The 4 inline custom-code MCP connectors. They ship inside the solution (so the
# agents' tools resolve to the same connector identity post-import), but solution
# import does NOT compile their inline .csx — steps/30_connectors.sh downloads each
# from the source env and `pac connector update`s it into the target to deploy the
# code. Connector ids are preserved across solution import, so the same id keys
# source and target. Format: "Display Name::source-connector-guid".
SOURCE_ENV_URL="https://org5d9d4b6b.crm.dynamics.com/"
CONNECTOR_IDS=(
  "Membership MCP v2::5d6180ed-0d6f-418c-8ccb-1360b7c33f88"
  "Order Management MCP::e4e7e713-5c3f-f111-bec6-70a8a59a4421"
  "Policy RAG MCP v2::32399478-9062-f111-ab0b-0022480a52c7"
  "Warehouse MCP::357a348b-d53f-f111-bec6-70a8a59a4421"
)

# Display names of the connectors that need a no-auth connection (step 40).
CONNECTOR_DISPLAY_NAMES=(
  "Membership MCP v2"
  "Order Management MCP"
  "Policy RAG MCP v2"
  "Warehouse MCP"
)

# --- Agents (publish order: children first, then parents) --------------------
# schemaname :: display name
AGENT_SCHEMA_CHILDREN=(
  "Default_StorePolicyAgent_s9s-u8"          # Store Policy Agent
  "Default_InventoryFullfilmentAgent_X-w2GP" # Inventory & Fulfillment Agent
)
AGENT_SCHEMA_PARENTS=(
  "cr26e_storeassociateassistant_ZQHUx1"     # Store Associate Assistant (Block Party)
  "Default_draft_IsBewO"                      # Returns & Service Assistant (Card Reissue)
)

# --- Timing ------------------------------------------------------------------
APIM_PROPAGATION_SECONDS=90   # wait after publish for inline MCP connectors to load
