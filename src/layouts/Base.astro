---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Enhanced Task Completion for Microsoft Copilot Studio' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={`${base}favicon.png`} />
    <title>{title}</title>
  </head>
  <body>
    <div class="gradient-bar"></div>
    <nav class="nav">
      <div class="nav__inner container">
        <a href={base} class="nav__brand">
          <span>CAT Feature Guides</span>
        </a>
        <div class="nav__links">
          <a href={`${base}#scenarios`}>Scenarios</a>
          <a href="https://github.com/microsoft/enhanced-task-completion/tree/main/sample">Get the sample</a>
          <a href="https://microsoft.github.io/mcscatblog/" class="nav__blog">Blog</a>
          <a href="https://github.com/microsoft/enhanced-task-completion" class="nav__github">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
        </div>
      </div>
    </nav>

    <slot />

    <script>
      document.querySelectorAll('.try-prompt').forEach(prompt => {
        const text = prompt.querySelector('.try-prompt__text')?.textContent?.trim();
        if (!text) return;
        const btn = document.createElement('button');
        btn.className = 'copy-btn';
        btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> Copy';
        btn.onclick = async () => {
          await navigator.clipboard.writeText(text);
          btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Copied!';
          btn.classList.add('copied');
          setTimeout(() => {
            btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> Copy';
            btn.classList.remove('copied');
          }, 2000);
        };
        prompt.appendChild(btn);
      });
    </script>

    <footer class="footer">
      <div class="container">
        <div class="footer__inner">
          <p>From the <a href="https://microsoft.github.io/mcscatblog/">Copilot Studio CAT</a> team. Licensed under MIT. <span class="footer__sep">&middot;</span> <a href="https://github.com/microsoft/enhanced-task-completion/issues/new?template=feedback.yml" class="footer__feedback"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg> Send feedback</a></p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(250, 250, 250, 0.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--c-border-subtle);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }
  .nav__brand {
    display: flex;
    align-items: center;
    font-weight: 700;
    font-size: 0.92rem;
    color: var(--c-text);
    letter-spacing: -0.01em;
  }
  .nav__brand:hover { color: var(--c-primary); }
  .nav__links {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--c-text-secondary);
  }
  .nav__links a:hover { color: var(--c-primary); }
  .nav__blog {
    color: var(--c-purple) !important;
    font-weight: 600 !important;
  }
  .nav__github {
    display: flex;
    align-items: center;
    color: var(--c-text-muted);
  }
  .nav__github:hover { color: var(--c-text); }

  @media (max-width: 600px) {
    .nav__inner { height: 48px; }
    .nav__brand { font-size: 0.82rem; }
    .nav__links { gap: var(--space-md); font-size: 0.78rem; }
    .nav__links a:not(.nav__github):not(.nav__blog) { display: none; }
  }

  .footer {
    margin-top: var(--space-4xl);
    padding: var(--space-xl) 0;
    border-top: 1px solid var(--c-border-subtle);
    text-align: center;
    font-size: 0.82rem;
    color: var(--c-text-muted);
  }
  .footer a {
    color: var(--c-purple);
    font-weight: 500;
  }
  .footer a:hover { color: var(--c-primary); }
  .footer__sep { margin: 0 4px; opacity: 0.3; }
  .footer__feedback {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    color: var(--c-text-muted) !important;
    font-weight: 400 !important;
    opacity: 0.7;
    transition: opacity 0.15s, color 0.15s;
  }
  .footer__feedback:hover { opacity: 1; color: var(--c-primary) !important; }
  .footer__feedback svg { opacity: 0.5; }
</style>
