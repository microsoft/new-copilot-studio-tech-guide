---
interface Props {
  title: string;
  description: string;
  capability: string;
  href: string;
  icon: string;
  tier: string;          // "Warm-up" | "Store associate" | "Store manager"
  accent: string;        // css color var name token: cyan | purple | pink | orange | green
  pillars: string[];     // small chips, e.g. ["1 MCP", "1 skill", "PDF out"]
}

const { title, description, capability, href, icon, tier, accent, pillars } = Astro.props;

const accentMap: Record<string, string> = {
  cyan: 'var(--c-primary)',
  purple: 'var(--c-purple)',
  pink: 'var(--c-pink)',
  orange: 'var(--c-orange)',
  green: 'var(--c-green)',
};
const accentColor = accentMap[accent] ?? accentMap.cyan;
---

<a href={href} class="card-wrapper" style={`--accent: ${accentColor};`}>
  <div class="card">
    <div class="card__art">
      <span class="card__icon">{icon}</span>
      <span class="card__tier">{tier}</span>
      <span class="card__scanline"></span>
    </div>
    <div class="card__body">
      <span class="badge badge--primary card__cap">{capability}</span>
      <h3 class="card__title">{title}</h3>
      <p class="card__desc">{description}</p>
      <div class="card__pillars">
        {pillars.map((p) => <span class="pill">{p}</span>)}
      </div>
      <span class="card__link">
        Explore scenario
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
      </span>
    </div>
  </div>
</a>

<style>
  .card-wrapper {
    position: relative;
    border-radius: var(--card-frame-radius);
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .card-wrapper::before {
    content: "";
    position: absolute;
    inset: 0;
    padding: var(--card-frame-thickness);
    border-radius: inherit;
    background: linear-gradient(135deg, var(--accent), transparent 70%);
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    z-index: 1;
  }
  .card-wrapper:hover::before { opacity: 1; }

  .card {
    display: flex;
    flex-direction: column;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--card-frame-radius);
    overflow: hidden;
    transition: all 0.25s ease;
    height: 100%;
  }
  .card-wrapper:hover .card {
    border-color: transparent;
    box-shadow: 0 14px 40px rgba(0, 0, 0, 0.45), 0 0 24px color-mix(in srgb, var(--accent) 22%, transparent);
    transform: translateY(-3px);
  }

  .card__art {
    position: relative;
    aspect-ratio: 16 / 7;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(ellipse 70% 90% at 50% 120%, color-mix(in srgb, var(--accent) 30%, transparent), transparent 70%),
      var(--c-bg-deep);
    border-bottom: 1px solid var(--c-border-subtle);
    overflow: hidden;
  }
  .card__icon {
    font-size: 2.6rem;
    filter: drop-shadow(0 0 14px color-mix(in srgb, var(--accent) 60%, transparent));
    z-index: 2;
  }
  .card__tier {
    position: absolute;
    top: 10px;
    left: 12px;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 45%, transparent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    padding: 3px 8px;
    border-radius: 20px;
    z-index: 2;
  }
  .card__scanline {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(0deg, rgba(255,255,255,0.025) 0 1px, transparent 1px 3px);
    z-index: 1;
  }

  .card__body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    flex: 1;
  }
  .card__cap { align-self: flex-start; }
  .card__title {
    font-size: 1.08rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--c-text);
    margin-top: 2px;
  }
  .card__desc {
    font-size: 0.88rem;
    color: var(--c-text-secondary);
    line-height: 1.6;
    flex: 1;
  }
  .card__pillars {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 2px;
  }
  .pill {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 600;
    color: var(--c-text-muted);
    background: var(--c-surface-raised);
    border: 1px solid var(--c-border-subtle);
    padding: 3px 8px;
    border-radius: 6px;
  }
  .card__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--accent);
    margin-top: var(--space-sm);
    transition: gap 0.2s ease;
  }
  .card-wrapper:hover .card__link { gap: 10px; }
</style>
